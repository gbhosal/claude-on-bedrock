{
  "_comment": "Copy to ~/.claude/settings.json for SSO-based Bedrock access with auto-refresh.",
  "awsAuthRefresh": "aws sso login --profile YOUR_SSO_PROFILE_NAME",
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_PROFILE": "YOUR_SSO_PROFILE_NAME",
    "AWS_REGION": "us-east-1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "us.anthropic.claude-opus-4-7",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "us.anthropic.claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "us.anthropic.claude-haiku-4-5-20251001-v1:0"
  }
}
