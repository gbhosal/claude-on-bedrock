aws_region = "us-east-1"

# LLM application IAM users — username = app name for self-evident ownership.
# Terraform creates the user, attaches the Bedrock invoke policy, and sets tags.
# Bedrock API keys and IAM access keys are provisioned and rotated outside Terraform.
llm_apps = {
  "app-ragbot-bedrock" = {
    APPACCESS  = "rag"
    GROUP      = "platform"
    COSTCENTER = "CC-1234"
    Note       = "RAG chatbot service — owned by platform team"
    Contact    = "platform-oncall@example.com"
  }
  "app-codeassist-prod" = {
    APPACCESS  = "codegen"
    GROUP      = "devtools"
    COSTCENTER = "CC-9999"
    Note       = "Internal code assistant"
    Contact    = "devtools-oncall@example.com"
  }
}
