aws_region = "us-east-1"

# Individual users — for local SDK development and integration testing ONLY.
# NOT for Claude Code CLI — see README.md. IAM username must match LDAP exactly.
developers = {
  "jsmith" = {
    APPACCESS  = "sdk-dev"
    GROUP      = "platform"
    COSTCENTER = "CC-1234"
    Note       = "Local SDK dev for RAG chatbot — NOT Claude Code"
    Contact    = "jsmith@example.com"
  }
}

# System users — IAM username = app name for self-evident ownership.
# These are NOT checked against LDAP; key rotation is triggered by app decommission.
llm_apps = {
  "app-ragbot-bedrock" = {
    APPACCESS  = "rag"
    GROUP      = "platform"
    COSTCENTER = "CC-1234"
    Note       = "RAG chatbot service — owned by platform team"
    Contact    = "platform-oncall@example.com"
  }
  "app-codeassist-prod" = {
    APPACCESS  = "codegen"
    GROUP      = "devtools"
    COSTCENTER = "CC-9999"
    Note       = "Internal code assistant"
    Contact    = "devtools@example.com"
  }
}
